  "components": [
    { "id": "users", "type": "external", "label": "Usuário/Operador", "sublabel": "Navegador Web", "row": 0, "col": 0 },
    { "id": "frontend", "type": "frontend", "label": "Frontend (React)", "sublabel": "State Management (Jotai)", "row": 0, "col": 1 },
    { "id": "api", "type": "backend", "label": "FastAPI API", "sublabel": "src/api/routes", "row": 0, "col": 2 },
    { "id": "db", "type": "database", "label": "Banco de Dados", "sublabel": "PostgreSQL / SQLModel", "row": 1, "col": 2 },
